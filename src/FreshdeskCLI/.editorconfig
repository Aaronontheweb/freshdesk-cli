root = false

[*.cs]
# Analyzer configuration for Freshdesk CLI

# Suppress rules that don't apply well to our use case
dotnet_diagnostic.CA1303.severity = none # Globalization - we're not localizing strings yet
dotnet_diagnostic.CA1515.severity = none # Public types in console app are fine
dotnet_diagnostic.CA1819.severity = none # Arrays in DTOs are needed for JSON serialization
dotnet_diagnostic.CA1062.severity = none # JSON converter parameters are guaranteed non-null by framework
dotnet_diagnostic.CA1055.severity = none # String URLs are fine for JSON DTOs
dotnet_diagnostic.CA1056.severity = none # String URLs are fine for JSON DTOs

# Keep these warnings - they're actually useful
# CA1008 - Enums should have zero value (FIXED)
# CA1305 - Specify IFormatProvider (should fix for culture issues)
# CA1307 - Specify StringComparison (should fix for perf/correctness)
# CA1310 - Specify StringComparison for correctness (should fix)
# CA1852 - Seal internal types (good for perf)